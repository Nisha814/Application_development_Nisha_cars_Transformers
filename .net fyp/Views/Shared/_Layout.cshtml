@using AutoCarePro.Data
@inject AppDbContext DbContext
@{
    var profile = DbContext.UserProfiles.FirstOrDefault() ?? new AutoCarePro.Models.UserProfile { FullName = "Nisha Admin", Role = "Operations Manager" };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The Nisha Cars Transformers - Customer and Vehicle Service Management System" />
    <title>@ViewData["Title"] - The Nisha Cars Transformers</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="sidebar" style="width: 260px; height: 100vh; background: #111827; color: white; position: fixed; top: 0; left: 0; display: flex; flex-direction: column; justify-content: space-between; padding: 20px;">
        <div>
            <div class="brand" style="display: flex; align-items: center; gap: 12px; margin-bottom: 40px;">
                <span class="material-symbols-outlined" style="background: #2563eb; color: white; padding: 8px; border-radius: 8px;">directions_car</span>
                <div>
                    <div style="font-weight: 700; font-size: 14px; line-height: 1.2;">The Nisha Cars<br/>Transformers</div>
                </div>
            </div>
            
            <div class="nav-links" style="display: flex; flex-direction: column; gap: 8px;">
                <a asp-controller="Home" asp-action="Index" class="nav-link" style="display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500; background: @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "#2563eb" : "transparent"); color: @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "white" : "#9ca3af");">
                    <span class="material-symbols-outlined">dashboard</span>
                    Dashboard
                </a>
                <a asp-controller="Records" asp-action="Index" class="nav-link" style="display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500; background: @(ViewData["ActivePage"]?.ToString() == "Records" ? "#2563eb" : "transparent"); color: @(ViewData["ActivePage"]?.ToString() == "Records" ? "white" : "#9ca3af");">
                    <span class="material-symbols-outlined">table_rows</span>
                    Customer Records
                </a>
                <a asp-controller="Registration" asp-action="Index" class="nav-link" style="display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500; background: @(ViewData["ActivePage"]?.ToString() == "Registration" ? "#2563eb" : "transparent"); color: @(ViewData["ActivePage"]?.ToString() == "Registration" ? "white" : "#9ca3af");">
                    <span class="material-symbols-outlined">person_add</span>
                    Register Customer
                </a>
                <a asp-controller="Vehicle" asp-action="Index" class="nav-link" style="display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500; background: @(ViewData["ActivePage"]?.ToString() == "Vehicle" ? "#2563eb" : "transparent"); color: @(ViewData["ActivePage"]?.ToString() == "Vehicle" ? "white" : "#9ca3af");">
                    <span class="material-symbols-outlined">directions_car</span>
                    Vehicles
                </a>
                <a asp-controller="History" asp-action="Index" class="nav-link" style="display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500; background: @(ViewData["ActivePage"]?.ToString() == "History" ? "#2563eb" : "transparent"); color: @(ViewData["ActivePage"]?.ToString() == "History" ? "white" : "#9ca3af");">
                    <span class="material-symbols-outlined">history</span>
                    History
                </a>
            </div>
        </div>
        
        <!-- Profile Section at Bottom -->
        <a asp-controller="Profile" asp-action="Index" class="profile-section" style="display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 8px; background: @(ViewData["ActivePage"]?.ToString() == "Profile" ? "#1f2937" : "transparent"); color: white; text-decoration: none; border: 1px solid #374151; transition: background 0.2s;">
            <div style="background: #2563eb; color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0;">
                @profile.Initials
            </div>
            <div style="flex: 1; min-width: 0;">
                <div style="font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@profile.FullName</div>
                <div style="font-size: 12px; color: #9ca3af; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@profile.Role</div>
            </div>
            <span class="material-symbols-outlined" style="color: #9ca3af; font-size: 18px;">settings</span>
        </a>
    </div>

    <main class="main-content" style="margin-left: 260px; padding: 40px; background: #f9fafb; min-height: 100vh;">
        @if (TempData["Success"] != null)
        {
            <div class="toast-notification success" id="toast" style="background: #fff; color: #065f46; border-left: 4px solid #10b981;">
                <span class="material-symbols-outlined" style="color: #10b981;">check_circle</span>
                @TempData["Success"]
            </div>
        }
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Auto-hide toast messages
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(function() {
                var toast = document.getElementById('toast');
                var errorToast = document.getElementById('error-toast');
                if (toast) toast.style.display = 'none';
                if (errorToast) errorToast.style.display = 'none';
            }, 4000);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
