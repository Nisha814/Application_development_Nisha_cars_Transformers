@model AutoCarePro.Models.Customer
@{
    ViewData["Title"] = "Customer Registration";
    ViewData["ActivePage"] = "Registration";
    var recentCustomers = ViewBag.RecentCustomers as List<AutoCarePro.Models.Customer> ?? new();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Customer Registration</h1>
        <p class="page-subtitle">Register a new customer to the system</p>
    </div>
</div>

<div class="form-card">
    <form asp-action="Index" method="post" id="registration-form">
        @Html.AntiForgeryToken()
        <div class="validation-summary">
            <span asp-validation-summary="ModelOnly" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="FullName" class="form-label">Full Name</label>
            <input asp-for="FullName" class="form-control" placeholder="Enter full name" id="input-fullname" />
            <span asp-validation-for="FullName" class="field-error"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="email@example.com" id="input-email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Phone" class="form-label">Phone Number</label>
                <input asp-for="Phone" class="form-control" placeholder="+91 98765 43210" id="input-phone" />
                <span asp-validation-for="Phone" class="field-error"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Address" class="form-label">Address</label>
            <textarea asp-for="Address" class="form-control form-textarea" placeholder="Enter complete address" id="input-address" rows="3"></textarea>
        </div>

        <button type="submit" class="btn-primary" id="btn-register-customer">
            <span class="material-symbols-outlined">person_add</span>
            Register Customer
        </button>
    </form>
</div>

<div class="card" style="margin-top:2rem;">
    <div class="card-header">
        <h2 class="card-title">Recently Registered Customers</h2>
    </div>
    <div class="customer-list">
        @foreach (var c in recentCustomers)
        {
            <div class="customer-item">
                <div class="avatar" style="background:@GetAvatarColor(c.FullName)">@GetInitials(c.FullName)</div>
                <div class="customer-info">
                    <div class="customer-name">@c.FullName</div>
                    <div class="customer-phone">@c.Email</div>
                </div>
                <div class="customer-right">
                    <div class="customer-date">@c.RegisteredDate.ToString("d/M/yyyy")</div>
                </div>
            </div>
        }
        @if (!recentCustomers.Any())
        {
            <p class="empty-state">No customers registered yet.</p>
        }
    </div>
</div>

@functions {
    string GetInitials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return parts[0].Length >= 2 ? parts[0][..2].ToUpper() : parts[0].ToUpper();
    }
    string GetAvatarColor(string name)
    {
        var colors = new[] { "#f59e0b", "#10b981", "#3b82f6", "#8b5cf6", "#ec4899", "#06b6d4", "#f97316", "#84cc16" };
        return colors[Math.Abs(name.GetHashCode()) % colors.Length];
    }
}
